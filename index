<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>JEWEL DROP</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }

body {
  background: #1a1c2c;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  min-height: -webkit-fill-available;
  font-family: 'Courier New', Courier, monospace;
  touch-action: none;
  overflow: hidden;
}

#outer-frame {
  background: #2e3350;
  padding: 6px;
  border: 4px solid #1a1c2c;
  box-shadow: 4px 4px 0 #1a1c2c;
}

#screen {
  display: -webkit-flex;
  display: flex;
  -webkit-flex-direction: row;
  flex-direction: row;
  background: #f4ead8;
  border: 3px solid #1a1c2c;
}

#field-wrap {
  position: relative;
  border-right: 3px solid #1a1c2c;
}

canvas { display: block; }

#side {
  width: 110px;
  background: #5a6394;
  display: -webkit-flex;
  display: flex;
  -webkit-flex-direction: column;
  flex-direction: column;
  padding: 4px;
  gap: 3px;
}

.next-box {
  background: #f4ead8;
  border: 2px solid #1a1c2c;
  padding: 3px;
  display: -webkit-flex;
  display: flex;
  -webkit-align-items: center;
  align-items: center;
  -webkit-justify-content: center;
  justify-content: center;
}

.stat-box {
  background: #2e3350;
  border: 2px solid #1a1c2c;
  padding: 2px 4px;
}
.stat-label {
  font-size: 9px;
  font-weight: bold;
  color: #f4ead8;
  letter-spacing: 1px;
  line-height: 1.3;
}
.stat-value {
  font-size: 13px;
  font-weight: bold;
  color: #ffd34e;
  letter-spacing: 2px;
  text-align: right;
  line-height: 1.2;
}
.stat-value.sm { font-size: 10px; letter-spacing: 1px; }

#overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,28,44,0.90);
  display: -webkit-flex;
  display: flex;
  -webkit-flex-direction: column;
  flex-direction: column;
  -webkit-align-items: center;
  align-items: center;
  -webkit-justify-content: center;
  justify-content: center;
  gap: 8px;
  z-index: 10;
}
#overlay h2 {
  color: #f4ead8;
  font-size: 15px;
  letter-spacing: 3px;
  text-align: center;
  line-height: 1.5;
}
#overlay p {
  color: #5a6394;
  font-size: 9px;
  letter-spacing: 1px;
  text-align: center;
  line-height: 2;
}
.gb-btn {
  background: #5a6394;
  border: 0;
  border-top: 2px solid #ffd34e;
  border-left: 2px solid #ffd34e;
  border-right: 2px solid #1a1c2c;
  border-bottom: 2px solid #1a1c2c;
  color: #1a1c2c;
  font-family: 'Courier New', Courier, monospace;
  font-weight: bold;
  font-size: 11px;
  letter-spacing: 2px;
  padding: 6px 16px;
  cursor: pointer;
}

#controls {
  display: -webkit-flex;
  display: flex;
  gap: 6px;
  margin-top: 6px;
  -webkit-flex-wrap: wrap;
  flex-wrap: wrap;
  -webkit-justify-content: center;
  justify-content: center;
  max-width: 320px;
}
.ctrl-key {
  background: #2e3350;
  border: 2px solid #1a1c2c;
  color: #f4ead8;
  font-family: 'Courier New', Courier, monospace;
  font-size: 9px;
  font-weight: bold;
  padding: 2px 5px;
  letter-spacing: 1px;
}

/* Touch buttons for mobile */
#touch-btns {
  display: -webkit-flex;
  display: flex;
  gap: 8px;
  margin-top: 8px;
  -webkit-justify-content: center;
  justify-content: center;
}
.t-btn {
  background: #2e3350;
  border: 2px solid #1a1c2c;
  border-top: 2px solid #5a6394;
  border-left: 2px solid #5a6394;
  color: #f4ead8;
  font-family: 'Courier New', Courier, monospace;
  font-size: 11px;
  font-weight: bold;
  padding: 8px 12px;
  cursor: pointer;
  -webkit-user-select: none;
  user-select: none;
  letter-spacing: 1px;
  min-width: 44px;
  text-align: center;
}
.t-btn:active {
  border-top: 2px solid #1a1c2c;
  border-left: 2px solid #1a1c2c;
  border-bottom: 2px solid #5a6394;
  border-right: 2px solid #5a6394;
