}

/* ===== 説明書オーバーレイ ===== */
#help-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(26,28,44,0.92);
  z-index: 100;
  justify-content: center;
  align-items: center;
  padding: 12px;
}
#help-overlay.show { display: flex; }
#help-book {
  background: #f4ead8;
  border: 4px solid #1a1c2c;
  box-shadow: 4px 4px 0 #1a1c2c, inset 0 0 0 2px #5a6394;
  max-width: 380px;
  max-height: 85vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 14px 16px;
  font-family: 'Courier New', Courier, monospace;
  color: #1a1c2c;
}
#help-book h3 {
  font-size: 15px;
  letter-spacing: 2px;
  text-align: center;
  border-bottom: 3px double #1a1c2c;
  padding-bottom: 6px;
  margin-bottom: 10px;
}
#help-book h4 {
  font-size: 12px;
  background: #1a1c2c;
  color: #f4ead8;
  padding: 3px 7px;
